# Versión WEB de Mándalo (mandalofront.ecohotelsamawe.com, Dokploy).
# Etapa "build": compila el SPA con expo export · etapa "production": nginx
# sirve dist/ (Docker Build Stage en Dokploy: "production", o vacío = última).
#
# ⚠️ Build args en Dokploy (se HORNEAN en el bundle JS al compilar):
#   EXPO_PUBLIC_CLIENT_API_KEY  (obligatorio) = APP_CLIENT_API_KEY del backend
#                               al que pegue esta web (dev o prod).
#   EXPO_PUBLIC_PROD_API_URL    (opcional) = URL del API. Sin él, el default
#                               de constants/api.ts es el PROD
#                               (https://apimandaloprod.ecohotelsamawe.com).
#                               Para la web DEV: https://apimandalo.ecohotelsamawe.com
#                               (+ la key de dev en el arg de arriba).

FROM node:22-alpine AS build

WORKDIR /app

# Misma versión de pnpm que generó el lockfile (patrón del backend)
RUN npm install -g pnpm@11.5.0

# pnpm-workspace.yaml es obligatorio (nodeLinker: hoisted + política de releases)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
RUN pnpm install --frozen-lockfile

COPY . .

ARG EXPO_PUBLIC_CLIENT_API_KEY
# Sin el arg (o vacío) quedaría "" horneado y el `??` de constants/api.ts no
# caería al default → el default vive acá.
ARG EXPO_PUBLIC_PROD_API_URL=https://apimandaloprod.ecohotelsamawe.com
ENV EXPO_PUBLIC_CLIENT_API_KEY=$EXPO_PUBLIC_CLIENT_API_KEY
ENV EXPO_PUBLIC_PROD_API_URL=$EXPO_PUBLIC_PROD_API_URL
ENV EXPO_NO_TELEMETRY=1

RUN npx expo export --platform web

FROM nginx:alpine AS production

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.web.conf /etc/nginx/conf.d/default.conf

# Runtime env: al arrancar, escribe /env.js con las env del CONTENEDOR y lo
# inyecta en el index.html (window.__MANDALO_ENV__, prioridad sobre lo
# horneado). Los build args de arriba quedan como fallback, pero la vía
# recomendada en Dokploy son las env normales + restart.
COPY docker-entrypoint.web.sh /docker-entrypoint.d/40-mandalo-env.sh
RUN chmod +x /docker-entrypoint.d/40-mandalo-env.sh

EXPOSE 80
