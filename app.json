{
  "expo": {
    "name": "Mándalo",
    "slug": "mandalo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontendmandalo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.mandalo.app",
      "supportsTablet": false,
      "config": {
        "googleMapsApiKey": "AIzaSyDJN3PWMQ625JiMNaVRVueITd37BRZDqIo"
      }
    },
    "android": {
      "package": "com.mandalo.app",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAeweO--d-iGHbMfGBbQ5lai2WleVxEGPI"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#F75929",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Mándalo usa tu ubicación para marcar tu dirección de entrega.",
          "locationAlwaysAndWhenInUsePermission": "Mándalo usa tu ubicación para que el cliente vea dónde va su pedido mientras lo llevas.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF5A3C",
          "defaultChannel": "orders-v2"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Mándalo accede a tus fotos para que elijas tu imagen de perfil o el logo de tu negocio.",
          "cameraPermission": "Mándalo usa la cámara para que tomes tu foto de perfil o la de tu negocio."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2dd7c249-c367-4191-b1f9-70a3ca4d84fa"
      }
    }
  }
}
